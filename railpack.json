{
    "$schema": "https://schema.railpack.com",
    "packages": {
        "go": "1.26.1"
    },
    "steps": {
        "build": {
            "commands": [
                {
                    "cmd": "env GOOS=linux GOARCH=amd64 go build -ldflags='-s' -o=./bin/linux_amd64/orchestrator ./server",
                    "customName": "Build an executable and store it bin folder."
                }
            ]
        }
    },
    "deploy": {
        "startCommand": "./bin/linux_amd64/orchestrator"
    }
}
